# ─── JSONC utilities ──────────────────────────────────────────────────────────


def find_key_block(text: str, key: str) -> "tuple[int, int] | None":
    """
    Find the byte span of  "key": { ... }  in JSONC text.
    Skips // line comments and /* */ block comments so their braces don't
    confuse the depth counter.
    Returns (start_of_key_quote, end_of_closing_brace) or None.
    """
    pat = re.compile(r'"' + re.escape(key) + r'"\s*:\s*\{')
    for m in pat.finditer(text):
        depth = 1
        i = m.end()
        in_str = esc = False
        while i < len(text) and depth > 0:
            c = text[i]
            if not in_str and c == "/" and i + 1 < len(text):
                if text[i + 1] == "/":
                    while i < len(text) and text[i] != "\n":
                        i += 1
                    continue
                if text[i + 1] == "*":
                    i += 2
                    while i + 1 < len(text) and not (text[i] == "*" and text[i + 1] == "/"):
                        i += 1
                    i += 2
                    continue
            if esc:
                esc = False
            elif c == "\\" and in_str:
                esc = True
            elif c == '"':
                in_str = not in_str
            elif not in_str:
                if c == "{":
                    depth += 1
                elif c == "}":
                    depth -= 1
                    if depth == 0:
                        return (m.start(), i + 1)
            i += 1
    return None


def _splice_server(block: str, server_name: str, server_json: str) -> str:
    """Replace or insert  "server_name": {...}  inside a JSON/JSONC object block."""
    span = find_key_block(block, server_name)
    replacement = f'"{server_name}": {server_json}'
    if span:
        return block[: span[0]] + replacement + block[span[1] :]
    close = block.rfind("}")
    prev = block[:close].rstrip()
    comma = "," if prev and prev[-1] not in ("{", ",") else ""
    return block[:close] + f"{comma}\n    {replacement}\n" + block[close:]


# ─── canonical config ─────────────────────────────────────────────────────────


def load_canonical() -> dict:
    if not CANONICAL.exists():
        _die(
            f"Canonical config not found: {CANONICAL}\n"
            "       Run 'mcp-relay init' to create it."
        )
    return json.loads(CANONICAL.read_text())


def save_canonical(data: dict) -> None:
    CANONICAL.write_text(json.dumps(data, indent=2) + "\n")


# ─── per-editor adapters ──────────────────────────────────────────────────────


def _adapt_zed(server: dict) -> str:
    """Zed: context_servers  →  {enabled, command/url, args, env}"""
    if server["transport"] == "remote":
        entry: dict = {"enabled": True, "url": server["url"]}
    else:
        cmd = server["command"]
        entry = {"enabled": True, "command": cmd[0], "args": cmd[1:]}
        if server.get("env"):
            entry["env"] = server["env"]
    return json.dumps(entry, indent="\t")


def _adapt_kilo_opencode(server: dict) -> str:
    """Kilo / opencode: mcp  →  {type, command/url, environment}"""
    if server["transport"] == "remote":
        entry: dict = {"type": "remote", "url": server["url"]}
    else:
        entry = {"type": "local", "command": server["command"]}
        if server.get("env"):
            entry["environment"] = server["env"]
    return json.dumps(entry, indent=2)


def _adapt_vscode(server: dict) -> str:
    """VS Code mcp.json: servers  →  {transport/command, url/args, env}"""
    if server["transport"] == "remote":
        entry: dict = {"transport": "streamable-http", "url": server["url"]}
    else:
        cmd = server["command"]
        entry = {"command": cmd[0], "args": cmd[1:]}
        if server.get("env"):
            entry["env"] = server["env"]
    return json.dumps(entry, indent=2)


def _adapt_claude(server: dict) -> str:
    """Claude Desktop / Cursor: mcpServers  →  {command/url, args, env}"""
    if server["transport"] == "remote":
        entry: dict = {"url": server["url"]}
    else:
        cmd = server["command"]
        entry = {"command": cmd[0], "args": cmd[1:]}
        if server.get("env"):
            entry["env"] = server["env"]
    return json.dumps(entry, indent=2)


ADAPTERS: dict = {
    "zed": _adapt_zed,
    "kilo_opencode": _adapt_kilo_opencode,
    "vscode": _adapt_vscode,
    "claude": _adapt_claude,
}

