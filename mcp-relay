# ─── helpers ──────────────────────────────────────────────────────────────────


def _die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def _ok(msg: str) -> None:
    print(f"  ✓  {msg}")


def _info(msg: str) -> None:
    print(f"  –  {msg}")


def _warn(msg: str) -> None:
    print(f"  !  {msg}")


def _detect_shell_rc() -> str:
    shell = os.environ.get("SHELL", "")
    if "fish" in shell:
        return "~/.config/fish/config.fish"
    if "zsh" in shell:
        return "~/.zshrc"
    return "~/.bashrc"


# ─── commands ─────────────────────────────────────────────────────────────────


def cmd_init(args: argparse.Namespace) -> None:
    """Create ~/.config/mcp/servers.json from a template."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if CANONICAL.exists() and not args.force:
        _info(f"Already exists: {CANONICAL}")
        _info("Use --force to overwrite, or 'mcp-relay edit' to modify.")
        return
    template = {
        "version": 1,
        "comment": "Single source of truth for MCP servers. Edit here; mcp-relay propagates changes.",
        "servers": {
            "betterstack": {"transport": "remote", "url": "https://mcp.betterstack.com"},
            "clickup": {"transport": "remote", "url": "https://mcp.clickup.com/mcp"},
            "mongodb": {
                "transport": "local",
                "command": ["pnpm", "dlx", "@mongodb-js/mongodb-mcp-server", "--readonly"],
                "env": {"MDB_MCP_CONNECTION_STRING": "mongodb+srv://user:pass@cluster/db"},
            },
        },
    }
    save_canonical(template)
    _ok(f"Created {CANONICAL}")
    _info("Fill in your real server details, then run 'mcp-relay sync'.")


def cmd_sync(args: argparse.Namespace) -> None:
    """Propagate canonical config to all active editor targets."""
    data = load_canonical()
    servers = data["servers"]
    targets = load_targets()
    editor = getattr(args, "editor", None)
    ts = active_targets(targets, editor)

    if editor and editor != "all" and not ts:
        all_names = [t["name"] for t in targets]
        _die(f"Unknown editor '{editor}'. Known: {', '.join(all_names)}")

    if not ts:
        _info("No active editor targets found.")
        return

    label = "mcp-relay sync" + (" (dry-run)" if getattr(args, "dry_run", False) else "")
    print(label + ":")
    for t in ts:
        changed, msg = _sync_one(t, servers, dry_run=getattr(args, "dry_run", False))
        sym = "✓" if changed else "–"
        print(f"  {sym}  {t['name']:<14}  {msg}")


def cmd_status(args: argparse.Namespace) -> None:
    """Show which servers are present/missing in each editor."""
    data = load_canonical()
    canonical_names = set(data["servers"].keys())
    targets = load_targets()

    print(f"Canonical : {CANONICAL}")
    print(f"Servers   : {', '.join(sorted(canonical_names))}\n")
    print(f"  {'Editor':<14}  {'Status':<10}  {'Present':<32}  Missing")
    print("  " + "-" * 74)

    for t in targets:
        path = _resolve(t["path"])
        enabled = t.get("enabled", True)
        if not path.exists():
            status = "not found" if enabled else "disabled"
            print(f"  {t['name']:<14}  {status}")
            continue
        text = path.read_text()
        only = t.get("only_servers")
        expected = {k for k in canonical_names if only is None or k in only}
        present = {n for n in expected if find_key_block(text, n)}
        missing = expected - present
        status = "ok" if not missing else "missing"
        print(
            f"  {t['name']:<14}  {status:<10}  "
            f"{', '.join(sorted(present)):<32}  {', '.join(sorted(missing))}"
        )


def cmd_diff(args: argparse.Namespace) -> None:
    """Show unified diff of what sync would change in each editor."""
    data = load_canonical()
    servers = data["servers"]
    targets = load_targets()
    any_diff = False

    for t in active_targets(targets):
        path = _resolve(t["path"])
        if not path.exists():
            continue
        original = path.read_text()

        only = t.get("only_servers")
        active = {k: v for k, v in servers.items() if only is None or k in only}
        adapt = ADAPTERS[t["adapter"]]
        text = original
        key = t["parent_key"]
        span = find_key_block(text, key)

        if span:
            block = text[span[0] : span[1]]
            for name, srv in active.items():
                block = _splice_server(block, name, adapt(srv))
            new_text = text[: span[0]] + block + text[span[1] :]
        else:
            new_text = text

        if new_text == original:
            continue
        any_diff = True
        lines = list(
            difflib.unified_diff(
                original.splitlines(keepends=True),
                new_text.splitlines(keepends=True),
                fromfile=f"{t['name']} (current)",
                tofile=f"{t['name']} (after sync)",
            )
        )
        print("".join(lines))

    if not any_diff:
        print("All editors are up-to-date.")


def cmd_list(args: argparse.Namespace) -> None:
    """List servers in canonical config."""
    data = load_canonical()
    servers = data.get("servers", {})
    if not servers:
        _info("No servers in canonical config. Run 'mcp-relay add' to add one.")
        return
    for name, s in servers.items():
        if s["transport"] == "remote":
            print(f"  {name:<18}  remote  {s['url']}")
        else:
            cmd = " ".join(s["command"])
            print(f"  {name:<18}  local   {cmd}")
            for k, v in (s.get("env") or {}).items():
                print(f"  {'':18}          {k}={v}")


def cmd_add(args: argparse.Namespace) -> None:
    """Add or update a server in canonical config, then sync."""
    data = load_canonical()
    servers = data.setdefault("servers", {})

    if args.name in servers and not args.force:
        _die(f"Server '{args.name}' already exists. Use --force to overwrite.")

    if args.remote:
        server: dict = {"transport": "remote", "url": args.remote}
    else:
        if not args.command:
            _die("--command is required for local servers.")
        cmd_parts = shlex.split(args.command)
        if args.arg:
            cmd_parts.extend(args.arg)
        server = {"transport": "local", "command": cmd_parts}
        if args.env:
            env: dict = {}
            for pair in args.env:
                k, _, v = pair.partition("=")
                env[k.strip()] = v.strip()
            server["env"] = env

    servers[args.name] = server
    save_canonical(data)
    _ok(f"Added '{args.name}' to {CANONICAL}")

    if not args.no_sync:
        class _SyncArgs:
            dry_run = False
            editor = "all"
        cmd_sync(_SyncArgs())


def cmd_remove(args: argparse.Namespace) -> None:
    """Remove a server from canonical config."""
    data = load_canonical()
    servers = data.get("servers", {})
    if args.name not in servers:
        _die(f"Server '{args.name}' not found.")
    del servers[args.name]
    save_canonical(data)
    _ok(f"Removed '{args.name}' from {CANONICAL}")


def cmd_edit(args: argparse.Namespace) -> None:
    """Open canonical config in $EDITOR."""
    editor = os.environ.get("EDITOR", "vi")
    os.execvp(editor, [editor, str(CANONICAL)])


def cmd_targets(args: argparse.Namespace) -> None:
    """List all known editor targets and whether they are active."""
    targets = load_targets()
    print(f"  {'Name':<14}  {'On':<4}  Path")
    print("  " + "-" * 70)
    for t in targets:
        path = _resolve(t["path"])
        enabled = "✓" if t.get("enabled", True) else "✗"
        exists = "(exists)" if path.exists() else "(not found)"
        only = t.get("only_servers")
        note = f"  [only: {', '.join(only)}]" if only else ""
        print(f"  {t['name']:<14}  {enabled:<4}  {path} {exists}{note}")


def cmd_install(args: argparse.Namespace) -> None:
    """Install mcp-relay to ~/.local/bin and set up auto-watch daemon."""
    script_path = Path(sys.argv[0]).resolve()

    # 1. Copy to ~/.local/bin
    BIN_PATH.parent.mkdir(parents=True, exist_ok=True)
    if script_path != BIN_PATH:
        shutil.copy2(script_path, BIN_PATH)
        BIN_PATH.chmod(0o755)
        _ok(f"Installed to {BIN_PATH}")
    else:
        _info(f"Already at {BIN_PATH}")

    # 2. Canonical config
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not CANONICAL.exists():
        save_canonical({"version": 1, "servers": {}})
        _ok(f"Created empty {CANONICAL}")

    # 3. Log dir
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)

    # 4. Auto-watch daemon
    system = platform.system()
    if system == "Darwin":
        _install_launchd()
    elif system == "Linux":
        _install_systemd()
    else:
        _warn(f"Auto-watch not supported on {system}. Run 'mcp-relay sync' manually.")

    # 5. PATH hint
    bin_dir = str(BIN_PATH.parent)
    if bin_dir not in os.environ.get("PATH", "").split(":"):
        rc = _detect_shell_rc()
        _warn(f"{bin_dir} is not in your PATH.")
        _info(f"Add to {rc}:  fish_add_path {bin_dir}  (or export PATH=\"{bin_dir}:$PATH\")")


def _install_launchd() -> None:
    LAUNCHD_PLIST.parent.mkdir(parents=True, exist_ok=True)
    LAUNCHD_PLIST.write_text(
        _LAUNCHD_PLIST.format(
            label=LAUNCHD_LABEL,
            script=str(BIN_PATH),
            canonical=str(CANONICAL),
            log=str(LOG_FILE),
        )
    )
    _ok(f"Wrote {LAUNCHD_PLIST}")
    subprocess.run(["launchctl", "unload", str(LAUNCHD_PLIST)], capture_output=True)
    r = subprocess.run(["launchctl", "load", str(LAUNCHD_PLIST)], capture_output=True, text=True)
    if r.returncode == 0:
        _ok(f"Loaded launchd agent  ({LAUNCHD_LABEL})")
    else:
        _warn(f"launchctl load failed: {r.stderr.strip()}")


def _install_systemd() -> None:
    python = shutil.which("python3") or sys.executable
    unit_dir = HOME / ".config" / "systemd" / "user"
    unit_dir.mkdir(parents=True, exist_ok=True)
    (unit_dir / "mcp-relay.service").write_text(
        _SYSTEMD_SERVICE.format(python=python, script=str(BIN_PATH), log=str(LOG_FILE))
    )
    (unit_dir / "mcp-relay.path").write_text(
        _SYSTEMD_PATH.format(canonical=str(CANONICAL))
    )
    _ok(f"Wrote systemd units in {unit_dir}")
    for cmd in [
        ["systemctl", "--user", "daemon-reload"],
        ["systemctl", "--user", "enable", "--now", "mcp-relay.path"],
    ]:
        r = subprocess.run(cmd, capture_output=True, text=True)
        (_ok if r.returncode == 0 else _warn)(
            " ".join(cmd) + (f": {r.stderr.strip()}" if r.returncode else "")
        )


def cmd_uninstall(args: argparse.Namespace) -> None:
    """Remove the auto-watch daemon and optionally the binary."""
    system = platform.system()
    if system == "Darwin":
        if LAUNCHD_PLIST.exists():
            subprocess.run(["launchctl", "unload", str(LAUNCHD_PLIST)], capture_output=True)
            LAUNCHD_PLIST.unlink()
            _ok(f"Removed {LAUNCHD_PLIST}")
        else:
            _info("No launchd plist found.")
    elif system == "Linux":
        unit_dir = HOME / ".config" / "systemd" / "user"
        for unit in ["mcp-relay.path", "mcp-relay.service"]:
            p = unit_dir / unit
            if p.exists():
                subprocess.run(
                    ["systemctl", "--user", "disable", "--now", unit], capture_output=True
                )
                p.unlink()
                _ok(f"Removed {p}")

    if not args.keep_binary and BIN_PATH.exists():
        BIN_PATH.unlink()
        _ok(f"Removed {BIN_PATH}")
    elif args.keep_binary:
        _info(f"Binary kept at {BIN_PATH}")


def cmd_logs(args: argparse.Namespace) -> None:
    """Tail the mcp-relay log file."""
    if not LOG_FILE.exists():
        _info(f"Log not found: {LOG_FILE}")
        return
    n = getattr(args, "lines", 40)
    os.execvp("tail", ["tail", f"-{n}", "-f", str(LOG_FILE)])


# ─── CLI wiring ───────────────────────────────────────────────────────────────


def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mcp-relay",
        description=f"mcp-relay {__version__} — Single source of truth for MCP server configs across AI editors.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=dedent(
            """\
            Canonical config  :  ~/.config/mcp/servers.json
            Custom targets    :  ~/.config/mcp/targets.json   (optional)
            Log               :  ~/.local/state/mcp-relay.log

            Quick start:
              mcp-relay init
              mcp-relay add betterstack --remote https://mcp.betterstack.com
              mcp-relay sync --dry-run
              mcp-relay install
            """
        ),
    )
    sub = p.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # init
    pi = sub.add_parser("init", help="Create ~/.config/mcp/servers.json from a template")
    pi.add_argument("--force", action="store_true", help="Overwrite existing config")
    pi.set_defaults(func=cmd_init)

    # sync
    ps = sub.add_parser("sync", help="Propagate canonical config to all editors")
    ps.add_argument("--dry-run", "-n", action="store_true", help="Preview without writing")
    ps.add_argument("--editor", "-e", metavar="NAME", help="Sync only this editor (or 'all')")
    ps.set_defaults(func=cmd_sync)

    # status
    pst = sub.add_parser("status", help="Show sync status of each editor")
    pst.set_defaults(func=cmd_status)

    # diff
    pd = sub.add_parser("diff", help="Show what sync would change in each editor")
    pd.set_defaults(func=cmd_diff)

    # list
    pl = sub.add_parser("list", help="List servers in canonical config")
    pl.set_defaults(func=cmd_list)

    # add
    pa = sub.add_parser("add", help="Add or update a server in canonical config")
    pa.add_argument("name", help="Server identifier (e.g. betterstack, mongodb)")
    grp = pa.add_mutually_exclusive_group()
    grp.add_argument("--remote", metavar="URL", help="Remote MCP server URL")
    grp.add_argument(
        "--command", metavar="CMD",
        help="Executable (for local server); may include args: 'pnpm dlx my-server'"
    )
    pa.add_argument(
        "--arg", metavar="ARG", action="append",
        help="Extra argument appended after --command (repeatable)"
    )
    pa.add_argument(
        "--env", metavar="KEY=VAL", action="append",
        help="Environment variable (repeatable)"
    )
    pa.add_argument("--force", action="store_true", help="Overwrite if exists")
    pa.add_argument("--no-sync", action="store_true", help="Skip sync after adding")
    pa.set_defaults(func=cmd_add)

    # remove
    pr = sub.add_parser("remove", help="Remove a server from canonical config")
    pr.add_argument("name", help="Server name")
    pr.set_defaults(func=cmd_remove)

    # edit
    pe = sub.add_parser("edit", help="Open canonical config in $EDITOR")
    pe.set_defaults(func=cmd_edit)

    # targets
    pt = sub.add_parser("targets", help="List all known editor targets and their state")
    pt.set_defaults(func=cmd_targets)

    # version
    p.add_argument("-V", "--version", action="version", version=f"%(prog)s {__version__}")

    # install
    pin = sub.add_parser(
        "install",
        help="Install mcp-relay to ~/.local/bin and set up auto-watch daemon",
    )
    pin.set_defaults(func=cmd_install)

    # uninstall
    pun = sub.add_parser("uninstall", help="Remove auto-watch daemon (and binary)")
    pun.add_argument("--keep-binary", action="store_true", help="Keep ~/.local/bin/mcp-relay")
    pun.set_defaults(func=cmd_uninstall)

    # logs
    plo = sub.add_parser("logs", help="Tail the mcp-relay log")
    plo.add_argument("-n", "--lines", type=int, default=40, help="Lines to show (default 40)")
    plo.set_defaults(func=cmd_logs)

    return p


def main() -> None:
    parser = _build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
