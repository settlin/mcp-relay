def _resolve(path_str: str) -> Path:
    p = Path(path_str.replace("~", str(HOME)))
    if p.is_symlink():
        return p.resolve()
    return p


def load_targets() -> list[dict]:
    targets = [dict(t) for t in BUILTIN_TARGETS]
    if CUSTOM_TARGETS_FILE.exists():
        custom = json.loads(CUSTOM_TARGETS_FILE.read_text())
        targets.extend(custom.get("targets", []))
    # Auto-enable targets that exist on disk but were marked disabled
    for t in targets:
        if "enabled" not in t:
            t["enabled"] = True
        elif not t["enabled"]:
            t["enabled"] = _resolve(t["path"]).exists()
    return targets


def active_targets(targets: list[dict], editor: str | None = None) -> list[dict]:
    ts = [t for t in targets if t.get("enabled")]
    if editor and editor != "all":
        ts = [t for t in ts if t["name"] == editor]
    return ts


# ─── core sync logic ──────────────────────────────────────────────────────────


def _sync_one(target: dict, servers: dict, dry_run: bool = False) -> tuple[bool, str]:
    """Sync canonical servers into one editor config. Returns (changed, label)."""
    path = _resolve(target["path"])
    if not path.exists():
        return False, f"skip (not found: {path})"

    only = target.get("only_servers")
    active = {k: v for k, v in servers.items() if only is None or k in only}
    adapt = ADAPTERS[target["adapter"]]
    original = path.read_text(encoding="utf-8")
    text = original
    key = target["parent_key"]
    span = find_key_block(text, key)

    if span:
        block = text[span[0] : span[1]]
        for name, srv in active.items():
            block = _splice_server(block, name, adapt(srv))
        new_text = text[: span[0]] + block + text[span[1] :]
    else:
        entries = "\n".join(
            f'    "{n}": {adapt(s)},' for n, s in active.items()
        ).rstrip(",")
        new_block = f'  "{key}": {{\n{entries}\n  }}'
        close = text.rfind("}")
        comma = "," if text[:close].rstrip()[-1] not in ("{", ",") else ""
        new_text = text[:close] + f"{comma}\n{new_block}\n" + text[close:]

    if new_text == original:
        return False, "up-to-date"

    if not dry_run:
        path.write_text(new_text, encoding="utf-8")
    return True, "updated (dry-run)" if dry_run else "updated"


